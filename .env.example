# === PaperBrief API Keys ===

# Google Gemini (primary LLM) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (fallback LLM) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs TTS — https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI (DALL-E 3 image gen + GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# === Optional Overrides ===
# ELEVENLABS_VOICE_ID=default_voice_id
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# === Scheduler Settings ===
SCHEDULE_TIMES=08:00,20:00
SCHEDULE_PAPERS_PER_RUN=1
SCHEDULE_LLM_PROVIDER=openrouter
SCHEDULE_LLM_MODEL=
SCHEDULE_TTS_PROVIDER=gtts
SCHEDULE_LANG=ID

# === Upload Platforms (true/false) ===
UPLOAD_YOUTUBE=false
UPLOAD_FACEBOOK=false
UPLOAD_TIKTOK=false

# === YouTube (OAuth — download client_secrets.json from Google Cloud Console) ===
# Place client_secrets.json in the project root directory

# === Facebook Reels ===
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# === TikTok ===
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
